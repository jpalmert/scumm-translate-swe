# Game files — never commit copyrighted content
game/

# Generated charset assets (produced by scripts/build_patcher.sh)
# Source of truth: internal/charset/bitmaps/*.bmp (Swedish BMPs) + game/monkey1/gen/ (extracted from game)
internal/charset/gen/

# game/ is already gitignored above; game/monkey1/gen/ holds all assets extracted
# from the game (CHAR blocks, BMPs, strings) — regenerate with scripts/extract.sh

# Generated dynamic name mapping (produced by extract_assets.sh / find_dynamic_names.py)
translation/*/dynamic_names.json

